root ::= "{" ws "\"intent\"" ws ":" ws action ws "}" ws
action ::= ( "\"find_large_files\"" ws "," ws "\"parameters\"" ws ":" ws find-large-files-params ws "," ws trailer ) | ( "\"find_process_using_port\"" ws "," ws "\"parameters\"" ws ":" ws find-process-using-port-params ws "," ws trailer ) | ( "\"kill_process\"" ws "," ws "\"parameters\"" ws ":" ws kill-process-params ws "," ws trailer ) | ( "\"install_package\"" ws "," ws "\"parameters\"" ws ":" ws install-package-params ws "," ws trailer ) | ( "\"start_service\"" ws "," ws "\"parameters\"" ws ":" ws start-service-params ws "," ws trailer ) | ( "\"stop_service\"" ws "," ws "\"parameters\"" ws ":" ws stop-service-params ws "," ws trailer ) | ( "\"open_file_or_folder\"" ws "," ws "\"parameters\"" ws ":" ws open-file-or-folder-params ws "," ws trailer ) | ( "\"compress_folder\"" ws "," ws "\"parameters\"" ws ":" ws compress-folder-params ws "," ws trailer ) | ( "\"create_backup\"" ws "," ws "\"parameters\"" ws ":" ws create-backup-params ws "," ws trailer ) | ( "\"explain_error\"" ws "," ws "\"parameters\"" ws ":" ws explain-error-params ws "," ws trailer ) | ( "\"fix_last_command\"" ws "," ws "\"parameters\"" ws ":" ws fix-last-command-params ws "," ws trailer ) | ( "\"update_packages\"" ws "," ws "\"parameters\"" ws ":" ws update-packages-params ws "," ws trailer ) | ( "\"check_system_health\"" ws "," ws "\"parameters\"" ws ":" ws check-system-health-params ws "," ws trailer ) | ( "\"inspect_logs\"" ws "," ws "\"parameters\"" ws ":" ws inspect-logs-params ws "," ws trailer ) | ( "\"list_processes\"" ws "," ws "\"parameters\"" ws ":" ws list-processes-params ws "," ws trailer ) | ( "\"disk_usage\"" ws "," ws "\"parameters\"" ws ":" ws disk-usage-params ws "," ws trailer ) | ( "\"network_connections\"" ws "," ws "\"parameters\"" ws ":" ws network-connections-params ws "," ws trailer ) | ( "\"git_status\"" ws "," ws "\"parameters\"" ws ":" ws git-status-params ws "," ws trailer ) | ( "\"show_memory\"" ws "," ws "\"parameters\"" ws ":" ws show-memory-params ws "," ws trailer ) | ( "\"create_project\"" ws "," ws "\"parameters\"" ws ":" ws create-project-params ws "," ws trailer ) | ( "\"git_commit_changes\"" ws "," ws "\"parameters\"" ws ":" ws git-commit-changes-params ws "," ws trailer ) | ( "\"ask_clarification\"" ws "," ws "\"parameters\"" ws ":" ws ask-clarification-params ws "," ws trailer )
find-large-files-member ::= "\"limit\"" ws ":" ws number | "\"min_size\"" ws ":" ws string | "\"path\"" ws ":" ws string
find-large-files-params ::= "{" ws ( find-large-files-member ( "," ws find-large-files-member )* )? "}" ws
find-process-using-port-member ::= "\"port\"" ws ":" ws number
find-process-using-port-params ::= "{" ws ( find-process-using-port-member ( "," ws find-process-using-port-member )* )? "}" ws
kill-process-member ::= "\"force\"" ws ":" ws boolean | "\"name\"" ws ":" ws string | "\"pid\"" ws ":" ws number | "\"port\"" ws ":" ws number
kill-process-params ::= "{" ws ( kill-process-member ( "," ws kill-process-member )* )? "}" ws
install-package-member ::= "\"manager\"" ws ":" ws string | "\"name\"" ws ":" ws string | "\"version\"" ws ":" ws string
install-package-params ::= "{" ws ( install-package-member ( "," ws install-package-member )* )? "}" ws
start-service-member ::= "\"name\"" ws ":" ws string
start-service-params ::= "{" ws ( start-service-member ( "," ws start-service-member )* )? "}" ws
stop-service-member ::= "\"name\"" ws ":" ws string
stop-service-params ::= "{" ws ( stop-service-member ( "," ws stop-service-member )* )? "}" ws
open-file-or-folder-member ::= "\"path\"" ws ":" ws string
open-file-or-folder-params ::= "{" ws ( open-file-or-folder-member ( "," ws open-file-or-folder-member )* )? "}" ws
compress-folder-member ::= "\"exclude\"" ws ":" ws array | "\"output\"" ws ":" ws string | "\"path\"" ws ":" ws string
compress-folder-params ::= "{" ws ( compress-folder-member ( "," ws compress-folder-member )* )? "}" ws
create-backup-member ::= "\"dest\"" ws ":" ws string | "\"path\"" ws ":" ws string
create-backup-params ::= "{" ws ( create-backup-member ( "," ws create-backup-member )* )? "}" ws
explain-error-member ::= "\"command\"" ws ":" ws string | "\"exit_code\"" ws ":" ws number | "\"stderr\"" ws ":" ws string
explain-error-params ::= "{" ws ( explain-error-member ( "," ws explain-error-member )* )? "}" ws
fix-last-command-member ::= "\"exit_code\"" ws ":" ws number | "\"last_command\"" ws ":" ws string | "\"stderr\"" ws ":" ws string
fix-last-command-params ::= "{" ws ( fix-last-command-member ( "," ws fix-last-command-member )* )? "}" ws
update-packages-member ::= "\"manager\"" ws ":" ws string | "\"scope\"" ws ":" ws string
update-packages-params ::= "{" ws ( update-packages-member ( "," ws update-packages-member )* )? "}" ws
check-system-health-params ::= "{" ws "}" ws
inspect-logs-member ::= "\"filter\"" ws ":" ws string | "\"since\"" ws ":" ws string | "\"source\"" ws ":" ws string
inspect-logs-params ::= "{" ws ( inspect-logs-member ( "," ws inspect-logs-member )* )? "}" ws
list-processes-params ::= "{" ws "}" ws
disk-usage-params ::= "{" ws "}" ws
network-connections-params ::= "{" ws "}" ws
git-status-params ::= "{" ws "}" ws
show-memory-params ::= "{" ws "}" ws
create-project-member ::= "\"kind\"" ws ":" ws string | "\"name\"" ws ":" ws string | "\"path\"" ws ":" ws string
create-project-params ::= "{" ws ( create-project-member ( "," ws create-project-member )* )? "}" ws
git-commit-changes-member ::= "\"add_all\"" ws ":" ws boolean | "\"message\"" ws ":" ws string
git-commit-changes-params ::= "{" ws ( git-commit-changes-member ( "," ws git-commit-changes-member )* )? "}" ws
ask-clarification-member ::= "\"options\"" ws ":" ws array | "\"question\"" ws ":" ws string
ask-clarification-params ::= "{" ws ( ask-clarification-member ( "," ws ask-clarification-member )* )? "}" ws
trailer ::= risk-field "\"requires_confirmation\"" ws ":" ws boolean ws "," ws "\"explanation\"" ws ":" ws string ws "," ws "\"confidence\"" ws ":" ws number ws
risk-field ::= ( "\"risk\"" ws ":" ws ( string | "null" ) ws "," ws )?
object ::= "{" ws ( member ( "," ws member )* )? "}" ws
member ::= string ws ":" ws value
array ::= "[" ws ( value ( "," ws value )* )? "]" ws
value ::= object | array | string | number | boolean | "null"
string ::= "\"" char* "\"" ws
char ::= [^"\\\x7F\x00-\x1F] | "\\" ( ["\\/bfnrt] | "u" hex hex hex hex )
hex ::= [0-9a-fA-F]
number ::= "-"? ( "0" | [1-9] [0-9]* ) ( "." [0-9]+ )? ( ( "e" | "E" ) ( "-" | "+" )? [0-9]+ )? ws
boolean ::= "true" | "false"
ws ::= [ \t\n]{0,16}